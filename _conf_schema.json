{
    "connection": {
        "description": "连接配置",
        "type": "object",
        "hint": "Hermes Agent 和 OneBot 的连接设置",
        "items": {
            "hermes_ws_url": {
                "type": "string",
                "description": "Hermes WebSocket 地址",
                "default": "ws://127.0.0.1:6701",
                "hint": "Hermes Agent 的 WebSocket 服务器地址"
            },
            "hermes_access_token": {
                "type": "string",
                "description": "Hermes 访问令牌",
                "default": "",
                "hint": "连接 Hermes 时的认证令牌，留空表示无需认证"
            },
            "onebot_api_url": {
                "type": "string",
                "description": "OneBot API 地址",
                "default": "http://127.0.0.1:5700",
                "hint": "NapCat 等 OneBot 实现的 HTTP API 地址"
            }
        }
    },
    "http_server": {
        "description": "HTTP API 服务器配置",
        "type": "object",
        "hint": "用于让 Hermes 调用 AstrBot 指令的 HTTP 服务器",
        "items": {
            "enable_http_server": {
                "type": "bool",
                "description": "启用 HTTP 服务器",
                "default": true,
                "hint": "是否启动 HTTP API 服务器供 Hermes 调用"
            },
            "http_server_port": {
                "type": "int",
                "description": "HTTP 服务器端口",
                "default": 8567,
                "hint": "HTTP API 服务器监听的端口号"
            },
            "http_server_token": {
                "type": "string",
                "description": "HTTP 服务器访问令牌",
                "default": "",
                "hint": "访问 HTTP API 时需要的认证令牌，留空表示无需认证"
            }
        }
    },
    "message_filter": {
        "description": "消息过滤配置",
        "type": "object",
        "hint": "控制哪些消息会被转发给 Hermes",
        "items": {
            "trigger_keywords": {
                "type": "list",
                "description": "触发关键词",
                "default": ["纳西妲", "hermes", "Hermes"],
                "hint": "消息中包含这些关键词时会转发给 Hermes",
                "items": {
                    "type": "string"
                }
            },
            "trigger_at_bot": {
                "type": "bool",
                "description": "@机器人时触发",
                "default": true,
                "hint": "是否在 @机器人 时转发消息给 Hermes"
            },
            "allowed_groups": {
                "type": "list",
                "description": "允许的群组",
                "default": [],
                "hint": "留空表示所有群组都可以触发。填写群号列表，只有这些群的消息会被转发。",
                "items": {
                    "type": "string"
                }
            },
            "allowed_users": {
                "type": "list",
                "description": "允许的用户",
                "default": [],
                "hint": "留空表示所有用户都可以触发。填写用户ID列表，只有这些用户的消息会被转发。",
                "items": {
                    "type": "string"
                }
            },
            "forward_all_messages": {
                "type": "bool",
                "description": "转发所有消息",
                "default": false,
                "hint": "是否转发所有消息给 Hermes（慎用，会产生大量请求）"
            },
            "max_message_length": {
                "type": "int",
                "description": "最大消息长度",
                "default": 2000,
                "hint": "超过此长度的消息会被截断"
            }
        }
    },
    "conflict_mode": {
        "description": "冲突处理策略",
        "type": "object",
        "hint": "当 LLM 和 Hermes 同时被唤醒时的处理方式",
        "items": {
            "llm_hermes_conflict_mode": {
                "type": "string",
                "description": "冲突处理模式",
                "default": "hermes_only",
                "options": ["hermes_only", "both", "llm_only"],
                "hint": "hermes_only=只用 Hermes 处理；both=同时唤醒，都处理；llm_only=优先用本地 LLM"
            }
        }
    },
    "approve_deny": {
        "description": "授权命令配置",
        "type": "object",
        "hint": "配置 /approve 和 /deny 命令的权限控制",
        "items": {
            "approve_enabled": {
                "type": "bool",
                "description": "启用 /approve 命令",
                "default": true,
                "hint": "是否允许使用 /approve 命令来授权 Hermes 指令执行"
            },
            "approve_users": {
                "type": "list",
                "description": "允许使用 /approve 的用户",
                "default": [],
                "hint": "留空表示所有用户都可以使用。填写用户ID列表，只有列表中的用户才能使用 /approve 命令。",
                "items": {
                    "type": "string"
                }
            },
            "deny_enabled": {
                "type": "bool",
                "description": "启用 /deny 命令",
                "default": true,
                "hint": "是否允许使用 /deny 命令来拒绝 Hermes 指令执行"
            },
            "deny_users": {
                "type": "list",
                "description": "允许使用 /deny 的用户",
                "default": [],
                "hint": "留空表示所有用户都可以使用。填写用户ID列表，只有列表中的用户才能使用 /deny 命令。",
                "items": {
                    "type": "string"
                }
            }
        }
    },
    "command_filter": {
        "description": "指令过滤配置",
        "type": "object",
        "hint": "控制哪些 AstrBot 指令可以通过 HTTP API 执行",
        "items": {
            "command_whitelist": {
                "type": "list",
                "description": "指令白名单",
                "default": [],
                "hint": "留空表示不限制。填写指令名称列表，只有这些指令可以通过 API 执行。",
                "items": {
                    "type": "string"
                }
            },
            "command_blacklist": {
                "type": "list",
                "description": "指令黑名单",
                "default": ["重启", "关机", "更新"],
                "hint": "这些指令不能通过 API 执行",
                "items": {
                    "type": "string"
                }
            }
        }
    }
}
