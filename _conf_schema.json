{
    "连接配置": {
        "description": "连接配置",
        "type": "object",
        "hint": "Hermes Agent 和 OneBot 的连接设置",
        "items": {
            "hermes_ws_url": {
                "type": "string",
                "description": "Hermes WebSocket 地址",
                "default": "ws://127.0.0.1:6701",
                "hint": "Hermes Agent 的 WebSocket 服务器地址"
            },
            "hermes_token": {
                "type": "string",
                "description": "Hermes 访问令牌",
                "default": "",
                "hint": "连接 Hermes 时的认证令牌，留空表示无需认证"
            },
            "onebot_api_url": {
                "type": "string",
                "description": "OneBot API 地址",
                "default": "http://127.0.0.1:5700",
                "hint": "NapCat 等 OneBot 实现的 HTTP API 地址"
            },
            "onebot_api_token": {
                "type": "string",
                "description": "OneBot API 访问令牌",
                "default": "",
                "hint": "NapCat 的 access_token，留空表示无需认证"
            }
        }
    },
    "http配置": {
        "description": "HTTP API 服务器",
        "type": "object",
        "hint": "用于让 Hermes 调用 AstrBot 指令的 HTTP 服务器",
        "items": {
            "启用_http_服务器": {
                "type": "bool",
                "description": "启用 HTTP 服务器",
                "default": true,
                "hint": "是否启动 HTTP API 服务器供 Hermes 调用"
            },
            "http_服务器_地址": {
                "type": "string",
                "description": "HTTP 服务器地址",
                "default": "127.0.0.1:8567",
                "hint": "HTTP API 服务器监听地址，格式: host:port（如 127.0.0.1:8567 或 0.0.0.0:8567）"
            },
            "http_服务器_token": {
                "type": "string",
                "description": "HTTP 服务器访问令牌",
                "default": "",
                "hint": "访问 HTTP API 时需要的认证令牌，留空表示无需认证"
            }
        }
    },
    "过滤配置": {
        "description": "消息过滤",
        "type": "object",
        "hint": "控制哪些消息会被转发给 Hermes",
        "items": {
            "触发关键词": {
                "type": "list",
                "description": "触发关键词",
                "default": [
                    "纳西妲",
                    "hermes",
                    "Hermes"
                ],
                "hint": "消息中包含这些关键词时会转发给 Hermes"
            },
            "触发艾特机器人": {
                "type": "bool",
                "description": "@机器人时触发",
                "default": false,
                "hint": "是否在 @机器人 时转发消息给 Hermes"
            },
            "允许的群组": {
                "type": "list",
                "description": "允许的群组",
                "default": [],
                "hint": "留空表示所有群组都可以触发。填写群号列表。"
            },
            "允许的用户": {
                "type": "list",
                "description": "允许的用户",
                "default": [],
                "hint": "留空表示所有用户都可以触发。填写用户ID列表。"
            },
            "转发所有消息": {
                "type": "bool",
                "description": "转发所有消息",
                "default": false,
                "hint": "是否转发所有消息给 Hermes（慎用）"
            },
            "引用唤醒": {
                "type": "bool",
                "description": "引用Hermes消息直接唤醒",
                "default": true,
                "hint": "引用Hermes发送的消息时，是否直接唤醒Hermes回复"
            }
        }
    },
    "冲突配置": {
        "description": "冲突处理",
        "type": "object",
        "hint": "当 LLM 和 Hermes 同时被唤醒时的处理方式",
        "items": {
            "同时唤醒处理方式": {
                "type": "string",
                "description": "冲突处理模式",
                "default": "只用Hermes",
                "options": ["只用Hermes", "不使用Hermes", "都处理"],
                "hint": "都处理：不拦截AstrBot的唤醒，并转发给Hermes"
            }
        }
    },
    "approve配置": {
        "description": "授权命令",
        "type": "object",
        "hint": "配置 /approve 和 /deny 命令的权限",
        "items": {
            "approve_启用": {
                "type": "bool",
                "description": "启用 /approve",
                "default": true,
                "hint": "是否允许使用 /approve 命令"
            },
            "approve_允许用户": {
                "type": "list",
                "description": "允许 /approve 的用户",
                "default": [],
                "hint": "留空表示所有用户都可以使用"
            },
            "deny_启用": {
                "type": "bool",
                "description": "启用 /deny",
                "default": true,
                "hint": "是否允许使用 /deny 命令"
            },
            "deny_允许用户": {
                "type": "list",
                "description": "允许 /deny 的用户",
                "default": [],
                "hint": "留空表示所有用户都可以使用"
            }
        }
    },
    "指令配置": {
        "description": "指令过滤",
        "type": "object",
        "hint": "控制哪些 AstrBot 指令可以通过 API 执行",
        "items": {
            "指令白名单": {
                "type": "list",
                "description": "指令白名单",
                "default": [],
                "hint": "留空表示不限制"
            },
            "指令黑名单": {
                "type": "list",
                "description": "指令黑名单",
                "default": ["重启", "关机", "更新"],
                "hint": "这些指令不能通过 API 执行"
            }
        }
    },
    "emoji配置": {
        "description": "表情回应",
        "type": "object",
        "hint": "自动贴表情回应功能",
        "items": {
            "回复消息贴表情": {
                "type": "bool",
                "description": "Hermes回复消息贴表情",
                "default": true,
                "hint": "Hermes 发送回复消息后自动给回复贴表情"
            },
            "转发时贴表情": {
                "type": "bool",
                "description": "转发消息时贴表情",
                "default": true,
                "hint": "用户消息触发唤醒并转发给 Hermes 时，给用户的原始消息贴表情"
            },
            "贴表情列表": {
                "type": "text",
                "description": "表情ID列表，用逗号分割每个表情，兼容中文逗号",
                "default": "12, 66, 76, 108, 122, 124, 144, 147, 180, 192, 201, 282, 297",
                "hint": "随机从这些表情ID中选一个贴上去"
            }
        }
    }
}
